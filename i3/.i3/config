#===General Options===#
set $mod Mod4

focus_follows_mouse no
hide_edge_borders both

font pango:Noto Sans 8

#===Variables===#
set $ws1 "1:🦊"
set $ws2 "2:🦬"
set $ws3 "3:🐧"
set $ws4 "4:📱"
set $ws5 "5:🎵"
set $location "19:-99" # cdmx

#===Startup Programs===#
exec --no-startup-id i3-msg 'workspace $ws2'
exec --no-startup-id ~/.fehbg
exec --no-startup-id emacs --bg-daemon
exec --no-startup-id dunst
exec --no-startup-id dropbox
exec --no-startup-id lxqt-policykit-agent
exec --no-startup-id picom \
     		     --no-fading-openclose \
     		     --inactive-opacity=0.9 \
     		     --shadow-exclude "class_g = 'zoom'"
exec --no-startup-id redshift -t 6500K:2500K -l $location
exec --no-startup-id xidlehook \
     		     --detect-sleep \
		     --not-when-fullscreen \
		     --not-when-audio \
		     --timer 240 \
		     'brightnessctl --save; brightnessctl set 0%' \
		     'brightnessctl --restore' \
		     --timer 15 \
		     'brightnessctl --restore; systemctl suspend' \
		     ''

#===Program shortcuts===#
bindsym $mod+shift+space exec --no-startup-id i3-dmenu-desktop
bindsym $mod+e exec pcmanfm
bindsym $mod+m exec --no-startup-id emacsclient -nca ""
bindsym $mod+Shift+m exec --no-startup-id emacsclient -ca "" -e \
	'(progn (org-agenda-list) (delete-other-windows))'
bindsym $mod+Return exec --no-startup-id emacsclient -ca "" -e '(vterm)'
bindsym $mod+Shift+Return exec --no-startup-id alacritty

mode "launcher" {
    bindsym f exec firefox-developer-edition; mode "default"
    bindsym z exec zoom; mode "default"
    bindsym d exec --no-startup-id discord; mode "default"
    bindsym s exec --no-startup-id spotify; mode "default"
    bindsym c exec --no-startup-id calibre; mode "default"
    bindsym v exec --no-startup-id vlc; mode "default"

    bindsym $mod+f exec firefox-developer-edition; mode "default"
    bindsym $mod+z exec zoom; mode "default"
    bindsym $mod+d exec --no-startup-id discord; mode "default"
    bindsym $mod+s exec --no-startup-id spotify; mode "default"
    bindsym $mod+c exec --no-startup-id calibre; mode "default"
    bindsym $mod+v exec --no-startup-id vlc; mode "default"

    bindsym Escape mode "default"
    bindsym Return mode "default"
}
bindsym $mod+space mode "launcher"

#===Scripts===#
bindsym $mod+F12 exec --no-startup-id pkill -SIGRTMIN+9 i3blocks #caffeine
bindsym $mod+Print exec --no-startup-id screenshot
bindsym $mod+Shift+Print exec --no-startup-id screenshot --interactive
bindsym $mod+Shift+q exec --no-startup-id exit-menu

#===Convenience Shortcuts===#
bindsym XF86AudioRaiseVolume exec --no-startup-id \
	pactl set-sink-volume @DEFAULT_SINK@ +5% \
	&& pkill -SIGRTMIN+10 i3blocks
bindsym Shift+XF86AudioRaiseVolume exec --no-startup-id \
	pactl set-sink-volume @DEFAULT_SINK@ 100% \
	&& pkill -SIGRTMIN+10 i3blocks
bindsym XF86AudioLowerVolume exec --no-startup-id \
	pactl set-sink-volume @DEFAULT_SINK@ -5% \
	&& pkill -SIGRTMIN+10 i3blocks
bindsym Shift+XF86AudioLowerVolume \
	exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ 0% \
	&& pkill -SIGRTMIN+10 i3blocks
bindsym XF86AudioMute exec --no-startup-id \
	pactl set-sink-mute @DEFAULT_SINK@ toggle \
	&& pkill -SIGRTMIN+10 i3blocks

bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym Shift+XF86MonBrightnessUp exec --no-startup-id brightnessctl set 100%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-
bindsym Shift+XF86MonBrightnessDown exec --no-startup-id  brightnessctl set 1

bindsym XF86KbdBrightnessUp \
	exec --no-startup-id brightnessctl --device="ite_8291::kbd_backlight" set +5%
bindsym Shift+XF86KbdBrightnessUp \
	exec --no-startup-id brightnessctl --device="ite_8291::kbd_backlight" set 100%
bindsym XF86KbdBrightnessDown \
	exec --no-startup-id brightnessctl --device="ite_8291::kbd_backlight" set 5%-
bindsym Shift+XF86KbdBrightnessDown \
	exec --no-startup-id brightnessctl --device="ite_8291::kbd_backlight" set 1%

#===Window Actions===#
assign [class="discord"] → $ws4
assign [class="zoom"] → $ws4
assign [class="telegram-desktop"] → $ws4
assign [class="Slack"] → $ws4
for_window [class="Spotify"] move to workspace $ws5

#===WM Shortcuts===#
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5

bindsym $mod+q kill

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+n split v
bindsym $mod+Shift+n split h

bindsym $mod+f fullscreen toggle

bindsym $mod+a layout stacking
bindsym $mod+s layout toggle split
bindsym $mod+d layout tabbed

floating_modifier $mod
bindsym $mod+Shift+p floating toggle
bindsym $mod+p focus mode_toggle

bindsym $mod+i focus parent
bindsym $mod+Shift+i focus child

bindsym $mod+o scratchpad show
bindsym $mod+Shift+o move scratchpad

# bindsym $mod+Left workspace prev
# bindsym $mod+Right workspace next

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

#===Visual===#
set $bg-color		 #0e1111
set $inactive-bg-color   #232b2b
set $text-color          #cccccc
set $inactive-text-color #626569
set $urgent-bg-color     #D0D0D0

#                       border              background         text                 indicator
client.focused          $bg-color           $bg-color          $text-color          #00ff00
client.unfocused        $inactive-bg-color  $inactive-bg-color $inactive-text-color #00ff00
client.focused_inactive $inactive-bg-color  $inactive-bg-color $inactive-text-color #00ff00
client.urgent           $urgent-bg-color    $urgent-bg-color   $text-color          #00ff00

# resize window (you can also use the mouse for that)
mode "resize" {
	bindsym h resize grow left 10 px or 10 ppt
	bindsym Shift+h resize shrink left 10 px or 10 ppt
	bindsym l resize grow right 10 px or 10 ppt
	bindsym Shift+l resize shrink right 10 px or 10 ppt
	bindsym k resize grow up 10 px or 10 ppt
	bindsym Shift+k resize shrink up 10 px or 10 ppt
	bindsym j resize grow down 10 px or 10 ppt
	bindsym Shift+j resize shrink down 10 px or 10 ppt

	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

bar {
	font pango:Noto Sans 14
	strip_workspace_numbers yes
	status_command i3blocks -c ~/.i3/i3blocks.conf
	colors {
	urgent_workspace   #000000 #FFFFFF
	}
}
