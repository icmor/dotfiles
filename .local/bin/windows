#!/bin/bash
# windows under QEMU+KVM

VM_DIR="$HOME"/VirtualMachines/windows
if [[ ! -d "$VM_DIR" ]]; then
    echo dir: $VM_DIR not found
    exit 0
fi

# TPM
EFI_DIR="$HOME"/VirtualMachines/efi
if [[ ! -d "$EFI_DIR" ]]; then
    echo dir: $EFI_DIR not found
    exit 0
fi

TPM_SOCK=/tmp/windows_swtpm.sock
TPM_RUNNING=$(ps -ef | grep swtpm | grep -v grep)
if [[ -z $TPM_RUNNING ]]; then
    echo starting swtpm...
    swtpm socket --tpm2 --tpmstate \
	  dir=$(dirname $TPM_SOCK) \
	  --ctrl type=unixio,path=$TPM_SOCK &
fi

qemu_args=(
    # q35 is required for secureboot
    -machine type=q35,accel=kvm
    # system drive
    -drive file=$VM_DIR/windows-disk.qcow2,index=0,media=disk,if=virtio,cache=none,aio=native
    # immutable mode (use commit all to commit changes)
    -snapshot
    # windows iso
    # -drive file=$VM_DIR/windows.iso,index=2,media=cdrom
    # fedora virtio drivers
    -drive file=$VM_DIR/virtio-win.iso,index=3,media=cdrom
    -boot menu=on
    # cpu windows enlightenments (created for hyper-v)
    -cpu host,hv_relaxed,hv_spinlocks=0x1fff,hv_vapic,hv_time,topoext=on
    -smp cores=4,threads=2,sockets=1
    -m 16G
    # TPM with manually signed certificate
    -drive if=pflash,format=raw,readonly=on,file=/usr/share/edk2/x64/OVMF_CODE.4m.fd
    -drive if=pflash,format=qcow2,file=$EFI_DIR/OVMF_VARS_SECUREBOOT.4m.fd.qcow2
    -chardev socket,id=chrtpm,path=$TPM_SOCK
    -tpmdev emulator,id=tpm0,chardev=chrtpm
    -device tpm-tis,tpmdev=tpm0
    -smbios type=11,path=$EFI_DIR/PkKek1.oemstr
    # virtio devices
    -nic user,model=virtio-net-pci
    -device virtio-serial-pci
    -device virtio-rng-pci
    -device qemu-xhci
    -device usb-tablet
    -device virtio-keyboard-pci
    -audiodev alsa,id=snd0,out.try-poll=off
    -device ich9-intel-hda -device hda-output,audiodev=snd0
    # SPICE
    -display spice-app
    -vga qxl
    -global qxl-vga.vram_size_mb=256
    -spice disable-ticketing=on
    -chardev spicevmc,id=vdagent,name=vdagent
    -device virtserialport,chardev=vdagent,name=com.redhat.spice.0
)

qemu-system-x86_64 "${qemu_args[@]}"
